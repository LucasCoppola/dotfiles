{
	"editor.accessibilitySupport": "off",
	"security.workspace.trust.untrustedFiles": "open",
	"workbench.startupEditor": "none",
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": false,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"html.format.indentInnerHtml": true,
	"workbench.colorTheme": "Material Theme Ocean",
	"prettier.semi": false,
	"prettier.tabWidth": 4,
	"prettier.trailingComma": "none",
	"html.format.enable": false,
	"html.format.preserveNewLines": false,
	"html.format.maxPreserveNewLines": 2,
	"prettier.useTabs": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"terminal.integrated.defaultProfile.windows": "Git Bash",
	"errorLens.enabled": true,
	"errorLens.enabledDiagnosticLevels": ["warning", "info", "error"],
	"errorLens.excludeBySource": ["ts(1005)"],
	"javascript.updateImportsOnFileMove.enabled": "always",
	"workbench.iconTheme": "symbols",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"prettier.useEditorConfig": false,
	"workbench.tree.indent": 15,
	"workbench.tree.renderIndentGuides": "always",
	"workbench.colorCustomizations": {
		"tree.indentGuidesStroke": "#05ef3c"
	},
	"workbench.sideBar.location": "right",
	"workbench.editor.closeOnFileDelete": true,
	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma"
	},
	"diffEditor.ignoreTrimWhitespace": false,
	"prettier.printWidth": 120,
	"editor.minimap.enabled": false,
	"symbols.hidesExplorerArrows": false,
	"explorer.decorations.colors": false,
	"editor.cursorBlinking": "phase",
	"workbench.layoutControl.enabled": false,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.altClickMovesCursor": false,
	"terminal.integrated.shellIntegration.history": 100,
	"terminal.integrated.shellIntegration.suggestEnabled": true,
	"terminal.integrated.profiles.windows": {
		"Git Bash": {
			"source": "Git Bash"
		},
		"Ubuntu (WSL)": {
			"path": "C:\\WINDOWS\\System32\\wsl.exe",
			"args": ["-d", "Ubuntu"]
		}
	},
	"window.menuBarVisibility": "hidden",
	"editor.fontWeight": "400",
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"tailwindCSS.experimental.configFile": null,
	"notebook.showCellStatusBar": "hidden",
	"editor.lineNumbers": "on",
	"git.ignoreRebaseWarning": true,
	"vim.smartRelativeLine": true,
	"vim.useSystemClipboard": true,
	"vim.hlsearch": true,
	"editor.suggest.insertMode": "replace",
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": ["]", "d"],
			"commands": ["editor.action.marker.next"]
		},
		{
			"before": ["[", "d"],
			"commands": ["editor.action.marker.prev"]
		},
		{
			"before": ["K"],
			"commands": ["editor.action.showDefinitionPreviewHover"]
		},
		{
			"before": ["<C-a>"],
			"after": ["g", "g", "V", "G"]
		},
		{
			"before": ["<leader>", "n", "o"],
			"commands": [":nohl"]
		},
		{
			"before": ["<leader>", "h"],
			"after": ["_"]
		},
		{
			"before": ["<leader>", "l"],
			"after": ["$"]
		},
		{
			"before": ["<leader>", "f"],
			"commands": ["workbench.action.quickOpen"]
		},
		{
			"before": [":"],
			"commands": ["workbench.action.showCommands"],
			"silent": true
		}
	],
	"vim.leader": "<space>",
	"vim.foldfix": true,
	"typescript.preferences.preferTypeOnlyAutoImports": true,
	"workbench.panel.opensMaximized": "always",
	"editor.fontFamily": "DM Mono",
	"editor.fontSize": 13,
	"terminal.integrated.fontSize": 13,
	"extensions.experimental.affinity": {
		"vscodevim.vim": 1
	},
	"files.exclude": {
		"**/node_modules": true,
		"**/package-lock.json": true,
		"**/.next": true
	},
	"terminal.integrated.gpuAcceleration": "on",
	"workbench.activityBar.location": "hidden",
	"breadcrumbs.enabled": false,
	"codeium.enableCodeLens": false,
	"codeium.enableConfig": {
		"*": true,
		"prisma": true
	},
	"codeium.enableExplainProblem": false
}
